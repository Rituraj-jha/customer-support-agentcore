# AWS / Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-micro-v1:0
BEDROCK_DEBUG_ERRORS=false

# LangGraph PostgreSQL checkpointer
POSTGRES_CHECKPOINT_DSN=postgresql://postgres:postgres@localhost:5434/langgraph
# If running inside docker-compose app container, use host 'postgres':
# POSTGRES_CHECKPOINT_DSN=postgresql://postgres:postgres@postgres:5432/langgraph
ALLOW_INMEMORY_CHECKPOINTER=false

# AgentCore Memory integration
AGENTCORE_MEMORY_ENDPOINT=
AGENTCORE_MEMORY_API_KEY=

# Support policy
REFUND_APPROVAL_THRESHOLD=100

# API runtime
PORT=8080
